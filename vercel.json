{
    "rewrites": [
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "shop.astraslide.co"
                }
            ],
            "destination": "/shop/index.html"
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "shop.astraslide.co"
                }
            ],
            "destination": "/shop/index.html"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "astraslide.co"
                }
            ],
            "destination": "/landing/index.html"
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "astraslide.co"
                }
            ],
            "destination": "/landing/index.html"
        },
        {
            "source": "/privacy-policy",
            "has": [
                {
                    "type": "host",
                    "value": "astraslide.co"
                }
            ],
            "destination": "/landing/privacy-policy.html"
        },
        {
            "source": "/return-policy",
            "has": [
                {
                    "type": "host",
                    "value": "astraslide.co"
                }
            ],
            "destination": "/landing/return-policy.html"
        },
        {
            "source": "/products/:id",
            "has": [
                {
                    "type": "host",
                    "value": "shop.astraslide.co"
                }
            ],
            "destination": "/shop/product.html?id=:id"
        },
        {
            "source": "/product/:path*",
            "has": [
                {
                    "type": "query",
                    "key": "_gl"
                }
            ],
            "destination": "/product/:path*",
            "permanent": true
        },
        {
            "source": "/product/:path*",
            "has": [
                {
                    "type": "query",
                    "key": "_ga"
                }
            ],
            "destination": "/product/:path*",
            "permanent": true
        },
        {
            "source": "/product/:path*",
            "has": [
                {
                    "type": "query",
                    "key": "_gcl_au"
                }
            ],
            "destination": "/product/:path*",
            "permanent": true
        }
    ]
}