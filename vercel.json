{
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/product/:id",
            "has": [
                {
                    "type": "host",
                    "value": "shop.astraslide.co"
                }
            ],
            "destination": "/shop/product"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "shop.astraslide.co"
                }
            ],
            "destination": "/shop/index"
        },
        {
            "source": "/privacy-policy",
            "has": [
                {
                    "type": "host",
                    "value": "astraslide.co"
                }
            ],
            "destination": "/landing/privacy-policy"
        },
        {
            "source": "/return-policy",
            "has": [
                {
                    "type": "host",
                    "value": "astraslide.co"
                }
            ],
            "destination": "/landing/return-policy"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "astraslide.co"
                }
            ],
            "destination": "/landing/index"
        }
    ]
}